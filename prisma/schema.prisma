// Prisma schema for BugImage
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         String   @default("admin") // admin | staff
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  dailyReportsCreated DailyReport[] @relation("ReportCreator")
  importLogs          ImportLog[]   @relation("ImportUser")
  qualityIssueGroupsCreated QualityIssueGroup[]     @relation("QualityIssueGroupCreator")
  qualityIssueImportLogs    QualityIssueImportLog[] @relation("QualityIssueImportUser")
}

/// Danh mục dùng cho autocomplete: product | customer | steel_grade | workshop | defect_type
model CatalogItem {
  id        String   @id @default(cuid())
  kind      String
  code      String?
  name      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([kind, name])
  @@index([kind, isActive, sortOrder])
}

/// Báo cáo tổng hợp theo ngày
model DailyReport {
  id             String    @id @default(cuid())
  reportDate     DateTime  @db.Date
  receivedDate   DateTime? @db.Date
  summaryDate    DateTime? @db.Date
  departmentName String    @default("Phòng nghiên cứu và công nghệ")
  reportCode     String?
  createdById    String?
  status         String    @default("draft") // draft | finalized
  hideFromTv     Boolean   @default(false)
  generalNote    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  createdBy  AdminUser?        @relation("ReportCreator", fields: [createdById], references: [id], onDelete: SetNull)
  lines      DailyReportLine[]
  importLogs ImportLog[]

  @@unique([reportDate])
  @@index([status, reportDate])
  @@index([hideFromTv, reportDate])
}

/// Chi tiết từng dòng lỗi trong báo cáo ngày
model DailyReportLine {
  id            String   @id @default(cuid())
  dailyReportId String
  lineNo        Int
  productName   String?
  customerName  String?
  steelGrade    String?
  inspectedQty  Int?
  passedQty     Int?
  passedRate    Float?
  processedQty  Int?
  processedRate Float?
  defectStatus  String?
  scrapQty      Int?
  scrapRate     Float?
  scrapStatus   String?
  workshopName  String?
  note          String?
  sourceType    String   @default("manual") // manual | excel
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  dailyReport DailyReport @relation(fields: [dailyReportId], references: [id], onDelete: Cascade)

  @@unique([dailyReportId, lineNo])
  @@index([dailyReportId])
}

/// Lịch sử import Excel theo báo cáo
model ImportLog {
  id            String   @id @default(cuid())
  fileName      String
  importedById  String?
  dailyReportId String
  totalRows     Int
  successRows   Int
  errorRows     Int
  errorFilePath String?
  createdAt     DateTime @default(now())

  dailyReport DailyReport @relation(fields: [dailyReportId], references: [id], onDelete: Cascade)
  importedBy  AdminUser?  @relation("ImportUser", fields: [importedById], references: [id], onDelete: SetNull)

  @@index([dailyReportId, createdAt])
}

model QualityIssueGroup {
  id                     String   @id @default(cuid())
  productName            String
  productNameNormalized  String
  customerName           String?
  customerNameNormalized String?
  steelGrade             String?
  sortOrder              Int      @default(0)
  isActive               Boolean  @default(true)
  hideFromTv             Boolean  @default(false)
  createdById            String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  createdBy AdminUser?          @relation("QualityIssueGroupCreator", fields: [createdById], references: [id], onDelete: SetNull)
  lines     QualityIssueLine[]

  @@index([sortOrder])
  @@index([isActive, sortOrder])
  @@index([hideFromTv, sortOrder])
  @@index([productNameNormalized])
  @@index([productNameNormalized, customerNameNormalized, steelGrade])
}

model QualityIssueLine {
  id             String   @id @default(cuid())
  groupId        String
  lineOrder      Int
  defectRateText String?
  defectName     String?
  actionPlan     String?
  progressStatus String?
  deadlineText   String?
  ownerName      String?
  note           String?
  styles         Json?
  sourceType     String   @default("manual") // manual | excel_import
  importLogId    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  group     QualityIssueGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  importLog QualityIssueImportLog? @relation(fields: [importLogId], references: [id], onDelete: SetNull)

  @@index([groupId, lineOrder])
  @@index([importLogId])
  @@unique([groupId, lineOrder])
}

model QualityIssueImportLog {
  id                   String   @id @default(cuid())
  fileName             String
  importedById         String?
  totalRows            Int
  successRows          Int
  errorRows            Int
  createdNewGroups     Int      @default(0)
  appendedExistingGroups Int    @default(0)
  skippedRows          Int      @default(0)
  mode                 String   @default("append") // append | upsert
  errorDetailJson      Json?
  errorFilePath        String?
  createdAt            DateTime @default(now())

  importedBy AdminUser?          @relation("QualityIssueImportUser", fields: [importedById], references: [id], onDelete: SetNull)
  lines      QualityIssueLine[]

  @@index([createdAt])
  @@index([importedById, createdAt])
}
